-- ======================== LOGIC ========================

-- Eat remote
local eatRemote = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("Event"):WaitForChild("Food"):WaitForChild("[C-S]TryEatFood")

-- Money remote
local moneyRemote = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("Event"):WaitForChild("Game"):WaitForChild("[C-S]PlayerEnd")

-- Spins remote (new)
local spinsRemote = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("Event"):WaitForChild("SeasonPass"):WaitForChild("[C-S]TryGetReward")

local eatEnabled = false
local moneyEnabled = false
local spinsEnabled = false

local eatConn, moneyConn, spinsConn = nil, nil, nil

-- Eat loop
local function startEat()
    if eatConn then eatConn:Disconnect() end
    eatConn = game:GetService("RunService").Heartbeat:Connect(function()
        if not eatEnabled then return end
        pcall(function() eatRemote:FireServer(999999) end)
        task.wait(0.065)
    end)
end

-- Money loop
local function startMoney()
    if moneyConn then moneyConn:Disconnect() end
    moneyConn = game:GetService("RunService").Heartbeat:Connect(function()
        if not moneyEnabled then return end
        pcall(function() moneyRemote:FireServer("Fight15") end)
        task.wait(0.12)
    end)
end

-- Spins loop (fires "1", 4)
local function startSpins()
    if spinsConn then spinsConn:Disconnect() end
    spinsConn = game:GetService("RunService").Heartbeat:Connect(function()
        if not spinsEnabled then return end
        pcall(function()
            spinsRemote:FireServer("1", 4)
        end)
        task.wait(0.09)   -- balanced speed for spins
    end)
end

-- Eat toggle
eatToggle.MouseButton1Click:Connect(function()
    eatEnabled = not eatEnabled
    if eatEnabled then
        eatToggle.Text = "DISABLE INFINITE EAT"
        eatToggle.TextColor3 = Color3.fromRGB(255, 70, 70)
        eatToggle.BackgroundColor3 = Color3.fromRGB(35, 10, 10)
        eatStatus.Text = "Status: ENABLED"
        eatStatus.TextColor3 = Color3.fromRGB(0, 255, 110)
        startEat()
    else
        eatToggle.Text = "ENABLE INFINITE EAT"
        eatToggle.TextColor3 = Color3.fromRGB(0, 255, 140)
        eatToggle.BackgroundColor3 = Color3.fromRGB(18, 18, 28)
        eatStatus.Text = "Status: DISABLED"
        eatStatus.TextColor3 = Color3.fromRGB(255, 70, 70)
        if eatConn then eatConn:Disconnect() eatConn = nil end
    end
end)

