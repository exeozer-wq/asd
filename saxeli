    pcall(function()
        local vec = Vector3.new(-714.8045043945312, 1.951197862625122, 1227.95166015625)
        
        local args = { vec, 99999999999999 }
        
        game:GetService("ReplicatedStorage")
            :WaitForChild("DropperEvents")
            :WaitForChild("CollectDrop")
            :FireServer(unpack(args))
