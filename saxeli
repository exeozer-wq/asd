btnCorner.Parent = btn

local btnStroke = Instance.new("UIStroke")
btnStroke.Color = Color3.fromRGB(0, 220, 100)
btnStroke.Thickness = 1.5
btnStroke.Transparency = 0.5
btnStroke.Parent = btn

-- Hover effect
btn.MouseEnter:Connect(function()
    btn:TweenSize(UDim2.new(0.92, 0, 0, 44), "Out", "Quad", 0.18, true)
    btnStroke.Transparency = 0.1
    uiStroke.Transparency = 0
end)

btn.MouseLeave:Connect(function()
    btn:TweenSize(UDim2.new(0.9, 0, 0, 40), "Out", "Quad", 0.18, true)
    btnStroke.Transparency = 0.5
    uiStroke.Transparency = 0.35
end)

-- Credit at bottom-right inside frame
local credit = Instance.new("TextLabel")
